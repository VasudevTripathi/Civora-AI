{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GovernmentSourceSchema",
  "type": "object",
  "properties": {
    "uuid": { "type": "string", "format": "uuid" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_updated": { "type": "string", "format": "date-time" },
    "verification_status": { "type": "string", "enum": ["unverified", "extraction_verified", "expert_verified", "certified"] },
    "source": { "type": "string", "format": "uri" },
    "applicable_state": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "applicable_district": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "dependencies": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "official_url": { "type": "string", "format": "uri" },
    "publishing_department": { "type": "string" },
    "notification_number": { "type": ["string", "null"] },
    "gazette_number": { "type": ["string", "null"] },
    "date_published": { "type": "string", "format": "date" },
    "date_verified": { "type": "string", "format": "date-time" },
    "verification_method": { "type": "string", "enum": ["manual_double_check", "api_cross_reference", "expert_notary_signing"] },
    "confidence_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "required": [
    "uuid",
    "version",
    "last_updated",
    "verification_status",
    "source",
    "applicable_state",
    "confidence",
    "official_url",
    "publishing_department",
    "date_published",
    "date_verified",
    "verification_method",
    "confidence_score"
  ]
}
