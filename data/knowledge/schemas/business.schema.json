{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BusinessSchema",
  "type": "object",
  "properties": {
    "uuid": { "type": "string", "format": "uuid" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_updated": { "type": "string", "format": "date-time" },
    "verification_status": { "type": "string", "enum": ["unverified", "extraction_verified", "expert_verified", "certified"] },
    "source": { "type": "string", "format": "uri" },
    "applicable_state": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "applicable_district": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "dependencies": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "business_category": { "type": "string" },
    "business_type": { "type": "string", "enum": ["LLC", "C-Corp", "Partnership", "Sole Proprietorship", "Private Limited"] },
    "primary_activity_code": { "type": "string" },
    "mandatory_license_uuids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
  },
  "required": [
    "uuid",
    "version",
    "last_updated",
    "verification_status",
    "source",
    "applicable_state",
    "confidence",
    "business_category",
    "business_type",
    "primary_activity_code",
    "mandatory_license_uuids"
  ]
}
