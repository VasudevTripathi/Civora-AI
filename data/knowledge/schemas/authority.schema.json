{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GovernmentAuthoritySchema",
  "type": "object",
  "properties": {
    "uuid": { "type": "string", "format": "uuid" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_updated": { "type": "string", "format": "date-time" },
    "verification_status": { "type": "string", "enum": ["unverified", "extraction_verified", "expert_verified", "certified"] },
    "source": { "type": "string", "format": "uri" },
    "applicable_state": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "applicable_district": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "dependencies": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "authority_name": { "type": "string" },
    "jurisdiction": { "type": "string", "enum": ["Federal", "State", "Municipal", "Local"] },
    "ministry_or_department": { "type": "string" },
    "official_website": { "type": "string", "format": "uri" }
  },
  "required": [
    "uuid",
    "version",
    "last_updated",
    "verification_status",
    "source",
    "applicable_state",
    "confidence",
    "authority_name",
    "jurisdiction"
  ]
}
