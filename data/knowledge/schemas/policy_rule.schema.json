{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyRuleSchema",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "authority": { "type": "string" },
    "condition": {
      "type": "object",
      "anyOf": [
        {
          "properties": {
            "fact": { "type": "string" },
            "operator": { "type": "string", "enum": [
              "equal", "equals",
              "notEqual", "not_equals", "notEquals",
              "greaterThan", "greater_than",
              "greaterThanOrEqual", "greater_than_or_equal",
              "lessThan", "less_than",
              "lessThanOrEqual", "less_than_or_equal",
              "in",
              "notIn", "not_in",
              "contains",
              "exists"
            ] },
            "value": { "type": ["string", "number", "boolean", "array"] }
          },
          "required": ["fact", "operator", "value"]
        },
        {
          "properties": {
            "all": {
              "type": "array",
              "items": { "$ref": "#/properties/condition" }
            }
          },
          "required": ["all"]
        },
        {
          "properties": {
            "any": {
              "type": "array",
              "items": { "$ref": "#/properties/condition" }
            }
          },
          "required": ["any"]
        },
        {
          "properties": {
            "not": {
              "$ref": "#/properties/condition"
            }
          },
          "required": ["not"]
        }
      ]
    },
    "action": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["require_license", "exempt_license", "charge_fee", "set_timeline", "apply_penalty", "trigger_notification"] },
        "params": {
          "type": "object",
          "properties": {
            "license_uuid": { "type": "string", "format": "uuid" },
            "fee_uuid": { "type": "string", "format": "uuid" },
            "timeline_uuid": { "type": "string", "format": "uuid" },
            "penalty_uuid": { "type": "string", "format": "uuid" },
            "notification_uuid": { "type": "string", "format": "uuid" },
            "value": { "type": ["string", "number", "boolean"] }
          }
        }
      },
      "required": ["type", "params"]
    },
    "priority": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fact": { "type": "string" },
          "operator": { "type": "string" },
          "value": { "type": ["string", "number", "boolean", "array"] }
        },
        "required": ["fact", "operator", "value"]
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "effective_date": { "type": "string", "format": "date" },
    "expiry_date": { "type": ["string", "null"], "format": "date" },
    "source": { "type": "string", "format": "uri" }
  },
  "required": [
    "id",
    "version",
    "description",
    "condition",
    "action",
    "priority",
    "effective_date",
    "source"
  ]
}
